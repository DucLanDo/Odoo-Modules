<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_time_tracking.TimeTrackingDashboard">
        <div class="o_alpha_time_tracking_dashboard">
            <div class="o_alpha_tt_card">
                <div class="o_alpha_tt_header">
                    <div class="o_alpha_tt_nav">
                        <button type="button" class="btn btn-outline-secondary o_alpha_tt_nav_btn" t-on-click="onPreviousDay">
                            ‹
                        </button>

                        <div class="o_alpha_tt_nav_center">
                            <h1 t-esc="state.selectedDateLabel"/>
                            <div class="o_alpha_tt_date_picker">
                                <input type="date" t-model="state.selectedDate" t-on-change="onDateChange"/>
                            </div>
                        </div>

                        <button type="button" class="btn btn-outline-secondary o_alpha_tt_nav_btn" t-on-click="onNextDay">
                            ›
                        </button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="o_alpha_tt_empty">Loading...</div>
                </t>

                <t t-elif="state.lines.length">
                    <div class="o_alpha_tt_lines">
                        <t t-foreach="state.lines" t-as="line" t-key="line.id">
                            <div class="o_alpha_tt_line_card">
                                <div class="o_alpha_tt_line_row">
                                    <div class="o_alpha_tt_time_from" t-esc="line.timeFrom"/>
                                    <div class="o_alpha_tt_duration" t-esc="line.duration"/>
                                    <div class="o_alpha_tt_time_to" t-esc="line.timeTo"/>
                                </div>

                                <t t-if="line.projectName">
                                    <div class="o_alpha_tt_meta_label">Project</div>
                                    <div class="o_alpha_tt_meta_text" t-esc="line.projectName"/>
                                </t>

                                <t t-if="line.activityDescription">
                                    <div class="o_alpha_tt_meta_label">Activity Description</div>
                                    <div class="o_alpha_tt_meta_text o_alpha_tt_multiline" t-esc="line.activityDescription"/>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>

                <t t-else="">
                    <div class="o_alpha_tt_empty">
                        No working times have been entered for this day yet.
                    </div>
                </t>

                <div class="o_alpha_tt_actions">
                    <button type="button" class="btn btn-primary" t-on-click="onClickEditWorkingTime">
                        Edit Working Time
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
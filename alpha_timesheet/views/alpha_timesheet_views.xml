<odoo>
    <!-- List View -->
    <record id="view_alpha_timesheet_entry_list" model="ir.ui.view">
        <field name="name">alpha.timesheet.entry.list</field>
        <field name="model">alpha.timesheet.entry</field>
        <field name="arch" type="xml">
            <list string="Timesheet Entries">
                <field name="date"/>
                <field name="status"
                    widget="badge"
                    decoration-success="status == 'done'"
                    decoration-danger="status == 'cancelled'"
                    decoration-warning="status == 'in_progress'"
                    decoration-info="status == 'todo'"/>
                <field name="partner_id"/>
                <field name="employee_user_id"/>
                <field name="time_from_display" string="Time From"/>
                <field name="time_to_display" string="Time To"/>
                <field name="duration_minutes"/>
                <field name="name"/>
            </list>
        </field>
    </record>

<!-- Form View -->
<record id="view_alpha_timesheet_entry_form" model="ir.ui.view">
    <field name="name">alpha.timesheet.entry.form</field>
    <field name="model">alpha.timesheet.entry</field>
    <field name="arch" type="xml">
        <form string="Timesheet Entry">
            <sheet>
                <group>
                    <group>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="employee_user_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="status"
                               widget="statusbar"
                               statusbar_visible="todo,in_progress,done,cancelled"
                               options="{'clickable': 1}"/>
                        <field name="time_from" widget="float_time"/>
                        <field name="time_to" widget="float_time"/>
                        <field name="duration_minutes" readonly="1"/>
                    </group>
                </group>

                <group string="Customer Details">
                    <group>
                        <field name="partner_street" readonly="1"/>
                        <field name="partner_zip" readonly="1"/>
                        <field name="partner_city" readonly="1"/>
                    </group>
                    <group>
                        <field name="partner_email" readonly="1"/>
                        <field name="partner_phone" readonly="1"/>
                    </group>
                </group>

                <separator string="Description"/>
                <field name="name"
                       widget="text"
                       nolabel="1"
                       placeholder="Enter description..."/>
            </sheet>
        </form>
    </field>
</record>

    <!-- Search View -->
    <record id="view_alpha_timesheet_entry_search" model="ir.ui.view">
        <field name="name">alpha.timesheet.entry.search</field>
        <field name="model">alpha.timesheet.entry</field>
        <field name="arch" type="xml">
            <search string="Search Timesheets">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="employee_user_id"/>
                <field name="status"/>

                <filter string="Today"
                        name="today"
                        domain="[('date', '=', context_today())]"/>

                <filter string="My Entries"
                        name="my_entries"
                        domain="[('employee_user_id', '=', uid)]"/>

                <separator/>

                <filter string="To Do"
                        name="status_todo"
                        domain="[('status', '=', 'todo')]"/>

                <filter string="In Progress"
                        name="status_in_progress"
                        domain="[('status', '=', 'in_progress')]"/>

                <filter string="Done"
                        name="status_done"
                        domain="[('status', '=', 'done')]"/>

                <filter string="Cancelled"
                        name="status_cancelled"
                        domain="[('status', '=', 'cancelled')]"/>

                <separator/>

                <filter string="Group by Date"
                        name="group_by_date"
                        context="{'group_by': 'date'}"/>

                <filter string="Group by Customer"
                        name="group_by_customer"
                        context="{'group_by': 'partner_id'}"/>

                <filter string="Group by Created By"
                        name="group_by_user"
                        context="{'group_by': 'employee_user_id'}"/>

                <filter string="Group by Status"
                        name="group_by_status"
                        context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_alpha_timesheet_entry" model="ir.actions.act_window">
        <field name="name">Timesheets</field>
        <field name="res_model">alpha.timesheet.entry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_alpha_timesheet_entry_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>
</odoo>
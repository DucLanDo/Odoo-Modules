<odoo>
    <record id="alpha_timesheet_rule_user_own" model="ir.rule">
        <field name="name">Timesheet: users see own entries</field>
        <field name="model_id" ref="model_alpha_timesheet_entry"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
</odoo>
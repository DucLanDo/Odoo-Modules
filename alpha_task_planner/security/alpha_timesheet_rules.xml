<odoo>
    <!-- Normale User sehen nur eigene Einträge -->
    <record id="alpha_timesheet_rule_user_own" model="ir.rule">
        <field name="name">Task Planner: users see own entries</field>
        <field name="model_id" ref="model_alpha_timesheet_entry"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Admins sehen alle Einträge -->
    <record id="alpha_timesheet_rule_admin_all" model="ir.rule">
        <field name="name">Task Planner: admins see all entries</field>
        <field name="model_id" ref="model_alpha_timesheet_entry"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>
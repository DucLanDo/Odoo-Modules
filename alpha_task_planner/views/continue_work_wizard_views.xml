<odoo>
    <record id="view_alpha_timesheet_continue_wizard_form" model="ir.ui.view">
        <field name="name">alpha.timesheet.continue.wizard.form</field>
        <field name="model">alpha.timesheet.continue.wizard</field>
        <field name="arch" type="xml">
            <form string="Continue Work">
                <sheet>
                    <group>
                        <field name="entry_id" readonly="1"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="time_from" widget="float_time"/>
                        <field name="time_to" widget="float_time"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_continue_work"
                            string="Create Continued Entry"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>